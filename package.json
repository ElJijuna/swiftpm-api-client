{
  "name": "swiftpm-api-client",
  "version": "1.0.0",
  "description": "TypeScript client for the Swift Package Registry and Swift Package Index APIs",
  "homepage": "https://github.com/ElJijuna/swiftpm-api-client#readme",
  "bugs": {
    "url": "https://github.com/ElJijuna/swiftpm-api-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElJijuna/swiftpm-api-client.git"
  },
  "license": "MIT",
  "author": "pilmee <pilmee@gmail.com> (https://github.com/ElJijuna)",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "swift",
    "swiftpm",
    "swift-package-manager",
    "swift-package-index",
    "registry",
    "api-client",
    "rest",
    "typescript"
  ],
  "scripts": {
    "build": "tsup",
    "check": "npm run lint && npm run format:check",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:client": "npm run build && node test-client/test.js",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/github": "^12.0.8",
    "@types/jest": "^30.0.0",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "semantic-release": "^25.0.3",
    "super-configs": "^1.12.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
